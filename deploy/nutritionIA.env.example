# Variables d'environnement du backend en production.
# À copier sur le VPS dans /etc/nutritionIA/nutritionIA.env (chmod 600, root:root)
# et référencé par nutritionIA.service via EnvironmentFile=.
# NE JAMAIS committer le fichier rempli.

# Active application-prod.properties (sinon défaut = dev → seed + DataInitializer !)
SPRING_PROFILES_ACTIVE=prod

# Base Postgres (conteneur Docker, publié sur la loopback uniquement)
DATABASE_URL=jdbc:postgresql://localhost:5432/nutritionAI
DB_USERNAME=gkl
DB_PASSWORD=change_me

# Secret JWT — minimum 32 caractères, sinon la clé HMAC est refusée au démarrage
JWT_SECRET=change_me_at_least_32_chars_long

# Origine(s) autorisée(s) pour CORS. Inutile si le front est servi en MÊME ORIGINE
# par nginx (recommandé), mais à renseigner si tu passes le front sur un sous-domaine.
ALLOWED_ORIGINS=https://votre-domaine.fr
